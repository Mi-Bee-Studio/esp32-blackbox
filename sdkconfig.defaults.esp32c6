# ESP32 Blackbox - ESP32-C6 专用配置
# Board: Seeed Studio XIAO ESP32C6

# Flash - XIAO ESP32C6 外接 4MB Flash, QIO 模式
# 注意: 部分批次为 8MB Flash, 如为 8MB 请改为 CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHMODE="qio"
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHFREQ="80m"

# 分区表 - 自定义分区表（扩大 app 分区至 1.875MB）
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# SPIFFS - 文件系统配置
CONFIG_SPIFFS_USE_MTIME=y

# mbedTLS - ESP32-C6 硬件加密加速 (AES/SHA/RSA/ECC)
CONFIG_MBEDTLS_HARDWARE_MPI=y
CONFIG_MBEDTLS_MPI_USE_INTERRUPT=y
CONFIG_MBEDTLS_HARDWARE_SHA=y
